# ─── Database ─────────────────────────────────────────────────────────────────
# LOCAL DEV (running backend with pnpm dev outside Docker):
DATABASE_URL="postgresql://user:pass@localhost:5432/auction_db"
# DOCKER (when running inside docker compose, change to):
# DATABASE_URL="postgresql://user:pass@postgres:5432/auction_db"

# ─── Redis ────────────────────────────────────────────────────────────────────
# LOCAL DEV:
REDIS_URL="redis://localhost:6379"
# DOCKER:
# REDIS_URL="redis://redis:6379"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── AI Service ───────────────────────────────────────────────────────────────
# LOCAL DEV:
AI_SERVICE_URL="http://localhost:8000"
# DOCKER:
# AI_SERVICE_URL="http://ai-service:8000"
AI_TIMEOUT_MS=400

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="noreply@auction-platform.com"

# ─── Sentry (optional — leave blank to disable) ───────────────────────────────
SENTRY_DSN=""

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3000
FRONTEND_URL="http://localhost:5173"
